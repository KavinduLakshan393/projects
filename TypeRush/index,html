      <span>Time: <span id="time">0s</span></span>
      <span>WPM: <span id="wpm">0</span></span>
      <span>Accuracy: <span id="accuracy">0%</span></span>
    </div>
    <button id="restart-btn" onclick="restart()">Restart</button>
  </div>
