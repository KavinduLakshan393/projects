<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Typing Speed Test</title>
  <style>
    /* same base CSS */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      background: #1a1a2e;
      color: #e0e0e0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
    }
    .container {
      background: #16213e;
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 700px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      text-align: center;
    }
    h1 {
      margin-bottom: 1.5rem;
      color: #e94560;
    }
    #text-display {
      background: #0f3460;
      padding: 1.5rem;
      border-radius: 12px;
      margin-bottom: 1.5rem;
      font-size: 1.2rem;
      line-height: 1.8;
      text-align: left;
      word-break: break-word;
      min-height: 100px;
    }
    /* Character styling */
    #text-display span {
      transition: color 0.1s, background 0.1s;
    }
    #text-display span.correct {
      color: #4ecca3;
    }
    #text-display span.incorrect {
      color: #e94560;
      background: rgba(233, 69, 96, 0.2);
    }
    #text-display span.current {
      background: rgba(255,255,255,0.2);
      border-radius: 2px;
    }
    #user-input {
      width: 100%;
      height: 120px;
      padding: 1rem;
      font-size: 1.1rem;
      border: 2px solid #533483;
      border-radius: 8px;
      background: #0f3460;
      color: #e0e0e0;
      resize: none;
      outline: none;
      transition: border-color 0.3s;
    }
    #user-input:focus {
      border-color: #e94560;
    }
    #stats {
      display: flex;
      justify-content: space-around;
      margin: 1.5rem 0;
      font-size: 1.1rem;
    }
    #stats span {
      background: #0f3460;
      padding: 0.5rem 1.2rem;
      border-radius: 8px;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
    }
    button {
      background: #e94560;
      color: white;
      border: none;
      padding: 0.8rem 2rem;
      border-radius: 8px;
      font-size: 1rem;
      cursor: pointer;
      transition: background 0.3s;
    }
    button:hover {
      background: #c23152;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Typing Speed Test</h1>
    <div id="text-display"></div>
    <textarea id="user-input" placeholder="Start typing here..."></textarea>
    <div id="stats">
      <span>⏱️ <span id="time">0s</span></span>
      <span>🚀 WPM: <span id="wpm">0</span></span>
      <span>🎯 Accuracy: <span id="accuracy">0%</span></span>
    </div>
    <button id="restart-btn">Restart</button>
  </div>
  <script>
    const texts = [
      "The quick brown fox jumps over the lazy dog.",
      "Pack my box with five dozen liquor jugs.",
      "How vexingly quick daft zebras jump!",
      "The five boxing wizards jump quickly.",
      "Sphinx of black quartz, judge my vow."
    ];

    let currentText = '';
    const textDisplay = document.getElementById('text-display');
    const userInput = document.getElementById('user-input');
    const restartBtn = document.getElementById('restart-btn');

    function loadRandomText() {
      const randomIndex = Math.floor(Math.random() * texts.length);
      currentText = texts[randomIndex];
      textDisplay.innerHTML = currentText.split('').map(ch => `<span>${ch}</span>`).join('');
    }

    function updateHighlights() {
      const inputText = userInput.value;
      const spans = textDisplay.querySelectorAll('span');
      
      // Remove all classes first
      spans.forEach(span => {
        span.classList.remove('correct', 'incorrect', 'current');
      });

      // Compare characters
      for (let i = 0; i < spans.length; i++) {
        if (i < inputText.length) {
          if (inputText[i] === currentText[i]) {
            spans[i].classList.add('correct');
          } else {
            spans[i].classList.add('incorrect');
          }
        }
      }

      // Set current character (next to type)
      if (inputText.length < spans.length) {
        spans[inputText.length].classList.add('current');
      }
    }

    userInput.addEventListener('input', updateHighlights);

    function restart() {
      loadRandomText();
      userInput.value = '';
      userInput.focus();
      updateHighlights(); // clear any leftover highlights
    }

    restart();
    restartBtn.addEventListener('click', restart);
  </script>
</body>
</html>